# Anthropic API key for /api/chat concierge
ANTHROPIC_API_KEY=

# Admin panel (/admin) — Google Sign-In with email allowlist.
# Create an OAuth 2.0 "Web application" client in Google Cloud Console.
# Authorized JavaScript origins should include your deployed URL(s) and http://localhost:3000
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=

# Comma-separated emails allowed to sign in. Defaults to devin@dwtailored.com when unset.
ADMIN_EMAIL=devin@dwtailored.com

# HMAC secret for signing admin session cookies (>= 32 random chars)
SESSION_SECRET=

# Vercel Blob — auto-injected by Vercel when Blob is enabled on the project.
BLOB_READ_WRITE_TOKEN=
